@startuml DiagramaCasoDeUso
title Diagrama de Casos de Uso - Telemedicina para Todos
left to right direction

skinparam packageStyle rectangle
skinparam shadowing false
skinparam actorStyle awesome

actor "Visitante" as Visitante
actor "Paciente" as Paciente
actor "Medico" as Medico
actor "Administrador" as Admin
actor "Servico de Email" as Email
actor "Servico de Notificacoes" as Notif
actor "Gateway SFU\n(MediaSoup)" as SFU

rectangle "Plataforma Telemedicina para Todos" {
  usecase "Cadastrar conta\nPaciente/Medico" as UC_Register
  (Verificar email) as UC_VerifyEmail
  usecase "Autenticar-se\n(login/logout)" as UC_Auth
  (Recuperar senha) as UC_ResetPassword

  usecase "Gerenciar perfil,\nsenha e avatar" as UC_Profile

  (Agendar consulta) as UC_Schedule
  (Reagendar consulta) as UC_Reschedule
  (Cancelar consulta) as UC_Cancel
  usecase "Gerenciar agenda\ne disponibilidade" as UC_ManageAgenda

  (Iniciar consulta online) as UC_StartConsult
  (Participar de videochamada) as UC_JoinCall
  (Trocar mensagens em tempo real) as UC_Chat

  (Visualizar prontuario) as UC_ViewRecord
  (Exportar prontuario em PDF) as UC_ExportPDF
  (Anexar documento ao prontuario) as UC_UploadDoc
  (Registrar diagnostico) as UC_Diagnosis
  (Emitir prescricao digital) as UC_Prescription
  (Solicitar exame) as UC_Exam
  (Registrar anotacao clinica) as UC_ClinicalNote
  (Registrar sinais vitais) as UC_Vitals
  (Emitir atestado) as UC_Certificate

  (Gerenciar notificacoes) as UC_Notifications
  (Enviar lembrete de consulta) as UC_Reminder

  (Gerenciar especializacoes) as UC_Specializations
  (Gerenciar timeline profissional) as UC_Timeline

  (Consentimento LGPD) as UC_LgpdConsent
  (Solicitar portabilidade de dados) as UC_LgpdPortability
  (Solicitar anonimização/exclusao de dados) as UC_LgpdErase

  (Auditar logs e acessos) as UC_Audit
}

Visitante --> UC_Register
Visitante --> UC_Auth
Visitante --> UC_ResetPassword

Paciente --> UC_VerifyEmail
Paciente --> UC_Auth
Paciente --> UC_Profile
Paciente --> UC_Schedule
Paciente --> UC_Reschedule
Paciente --> UC_Cancel
Paciente --> UC_JoinCall
Paciente --> UC_Chat
Paciente --> UC_ViewRecord
Paciente --> UC_ExportPDF
Paciente --> UC_UploadDoc
Paciente --> UC_Notifications
Paciente --> UC_LgpdConsent
Paciente --> UC_LgpdPortability
Paciente --> UC_LgpdErase

Medico --> UC_VerifyEmail
Medico --> UC_Auth
Medico --> UC_Profile
Medico --> UC_ManageAgenda
Medico --> UC_StartConsult
Medico --> UC_JoinCall
Medico --> UC_Chat
Medico --> UC_ViewRecord
Medico --> UC_UploadDoc
Medico --> UC_Diagnosis
Medico --> UC_Prescription
Medico --> UC_Exam
Medico --> UC_ClinicalNote
Medico --> UC_Vitals
Medico --> UC_Certificate
Medico --> UC_Notifications
Medico --> UC_Timeline

Admin --> UC_Specializations
Admin --> UC_Audit
Admin --> UC_Notifications

UC_Register .> UC_VerifyEmail : <<include>>
UC_StartConsult .> UC_JoinCall : <<include>>
UC_JoinCall .> UC_Chat : <<extend>>
UC_ViewRecord .> UC_ExportPDF : <<extend>>
UC_ViewRecord .> UC_UploadDoc : <<extend>>
UC_StartConsult .> UC_Diagnosis : <<extend>>
UC_StartConsult .> UC_Prescription : <<extend>>
UC_StartConsult .> UC_Exam : <<extend>>
UC_StartConsult .> UC_ClinicalNote : <<extend>>
UC_StartConsult .> UC_Vitals : <<extend>>
UC_StartConsult .> UC_Certificate : <<extend>>
UC_Schedule .> UC_Reminder : <<include>>
UC_Reschedule .> UC_Reminder : <<include>>
UC_Cancel .> UC_Reminder : <<include>>

UC_VerifyEmail --> Email
UC_Reminder --> Notif
UC_Notifications --> Notif
UC_JoinCall --> SFU

@enduml
