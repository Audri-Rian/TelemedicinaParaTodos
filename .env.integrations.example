# -----------------------------------------------------------------------------
# Template de variáveis de integrações
# -----------------------------------------------------------------------------
# Uso recomendado:
# 1) Copie estas variáveis para o seu .env principal (não carregar arquivo extra no Laravel)
# 2) Preencha valores reais por ambiente (local/staging/production)
# 3) Nunca comite segredos reais

# FHIR base
FHIR_SYSTEM_URL=https://telemedicina.example.com/fhir

# RNDS
RNDS_ENABLED=false
RNDS_ENVIRONMENT=homologation
RNDS_BASE_URL=https://ehr-services-hmg.saude.gov.br/api
RNDS_AUTH_URL=https://ehr-auth-hmg.saude.gov.br/api
RNDS_CNES=
RNDS_CERTIFICATE_PATH=
RNDS_CERTIFICATE_PASSWORD=

# Fila dedicada de integrações
INTEGRATION_QUEUE_CONNECTION=rabbitmq
INTEGRATION_QUEUE_NAME=integrations

# Timeouts de integração (descomente para sobrescrever defaults do config/integrations.php)
# INTEGRATION_LAB_CONNECT_TIMEOUT=5
# INTEGRATION_LAB_RESPONSE_TIMEOUT=15
# INTEGRATION_PHARMACY_CONNECT_TIMEOUT=3
# INTEGRATION_PHARMACY_RESPONSE_TIMEOUT=10
# INTEGRATION_HOSPITAL_CONNECT_TIMEOUT=5
# INTEGRATION_HOSPITAL_RESPONSE_TIMEOUT=15
# INTEGRATION_INSURANCE_CONNECT_TIMEOUT=5
# INTEGRATION_INSURANCE_RESPONSE_TIMEOUT=15
# INTEGRATION_RNDS_CONNECT_TIMEOUT=10
# INTEGRATION_RNDS_RESPONSE_TIMEOUT=60

# Circuit breaker (descomente para sobrescrever defaults)
# CB_LAB_FAILURES=5
# CB_LAB_COOLING=60
# CB_PHARMACY_FAILURES=3
# CB_PHARMACY_COOLING=30
# CB_HOSPITAL_FAILURES=5
# CB_HOSPITAL_COOLING=60
# CB_INSURANCE_FAILURES=5
# CB_INSURANCE_COOLING=60
# CB_RNDS_FAILURES=5
# CB_RNDS_COOLING=120

# Retry/Idempotência (descomente para sobrescrever defaults)
# RETRY_LAB_MAX=3
# RETRY_PHARMACY_MAX=3
# RETRY_HOSPITAL_MAX=3
# RETRY_INSURANCE_MAX=3
# RETRY_RNDS_MAX=5
