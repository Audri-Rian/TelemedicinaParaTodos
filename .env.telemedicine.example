# -----------------------------------------------------------------------------
# Template de variáveis de telemedicina (núcleo)
# -----------------------------------------------------------------------------
# Uso recomendado:
# 1) Copie estas variáveis para o .env principal
# 2) Mantenha um .env por ambiente (local/staging/production)
# 3) Ajuste só o necessário por ambiente

# App
APP_NAME="Telemedicina para Todos"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# Banco
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=telemedicina
DB_USERNAME=root
DB_PASSWORD=

# Sessão/Cache/Fila (base)
CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database

# Realtime (opcional)
BROADCAST_CONNECTION=log
# BROADCAST_CONNECTION=reverb
# REVERB_APP_ID=
# REVERB_APP_KEY=
# REVERB_APP_SECRET=
# REVERB_HOST=localhost
# REVERB_PORT=8080
# REVERB_SCHEME=http

# Assinatura digital de documentos
SIGNATURE_DRIVER=null
ICP_PROVIDER=
ICP_CERT_PATH=
ICP_CERT_PASSWORD=
ICP_API_ENDPOINT=
ICP_API_KEY=
SIGNATURE_VERIFICATION_URL_TEMPLATE=/verify/{code}

# Exportação assíncrona de prontuário
MEDICAL_RECORD_EXPORT_QUEUE_CONNECTION=database
MEDICAL_RECORD_EXPORT_QUEUE_NAME=default

# Uploads
UPLOAD_AVATAR_MAX_KB=5120
UPLOAD_MEDICAL_DOCUMENT_MAX_KB=10240
