# =============================================================================
# Deploy PC1 consolidado — copie para .env e preencha os valores reais.
# Uso: cd deploy/pc1 && cp .env.example .env && nano .env
# =============================================================================

APP_NAME="Telemedicina Para Todos"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.seudominio.com
ASSET_URL=

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# -----------------------------------------------------------------------------
# Portas publicadas no host PC1.
# Defaults sensíveis ficam bindados em 127.0.0.1; exponha LAN só se necessário.
# -----------------------------------------------------------------------------
NGINX_PUBLISH_PORT=80
DB_PUBLISH_PORT=127.0.0.1:5432
REDIS_PUBLISH_PORT=127.0.0.1:6379
RABBITMQ_PUBLISH_PORT=127.0.0.1:5672
RABBITMQ_MANAGEMENT_PUBLISH_PORT=127.0.0.1:15672
MINIO_API_PUBLISH_PORT=127.0.0.1:9000
MINIO_CONSOLE_PUBLISH_PORT=127.0.0.1:9001

# -----------------------------------------------------------------------------
# Banco de dados PostgreSQL
# -----------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=telemedicina
DB_USERNAME=postgres
DB_PASSWORD=

# -----------------------------------------------------------------------------
# Redis: cache, sessão e fila padrão
# -----------------------------------------------------------------------------
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

# -----------------------------------------------------------------------------
# Filas
# -----------------------------------------------------------------------------
QUEUE_CONNECTION=redis
REDIS_QUEUE=default
INTEGRATION_QUEUE_CONNECTION=rabbitmq
INTEGRATION_QUEUE_NAME=integrations
MEDICAL_RECORD_EXPORT_QUEUE_CONNECTION=rabbitmq
MEDICAL_RECORD_EXPORT_QUEUE_NAME=integrations

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=telemedicina
RABBITMQ_PASSWORD=
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=default

# -----------------------------------------------------------------------------
# Reverb: navegador usa ws.<dominio> via Cloudflare Tunnel + Nginx
# -----------------------------------------------------------------------------
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=telemedicina-pc1
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=ws.seudominio.com
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_SCALING_ENABLED=true
REVERB_SCALING_CHANNEL=reverb

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# -----------------------------------------------------------------------------
# MinIO / S3 local. Laravel usa credencial de aplicação, nao root.
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=s3_private
AWS_ACCESS_KEY_ID=telemedicina-app
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=telemedicina-private
AWS_PRIVATE_BUCKET=telemedicina-private
AWS_PRIVATE_ROOT=private
AWS_PRIVATE_URL=
AWS_PUBLIC_BUCKET=telemedicina-public
AWS_PUBLIC_ROOT=public
AWS_PUBLIC_URL=
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_APP_USER=telemedicina-app
MINIO_APP_PASSWORD=
MINIO_DATA_PATH=/home/pc1intelceleron/minio/data

MEDICAL_RECORDS_DISK=s3_private
MEDICAL_DOCUMENTS_DISK=s3_private
LGPD_EXPORTS_DISK=s3_private
PRESCRIPTIONS_DISK=s3_private
CERTIFICATES_DISK=s3_private
CHAT_ATTACHMENTS_DISK=s3_private
INTEGRATION_DOCUMENTS_DISK=s3_private
VIDEO_RECORDINGS_DISK=s3_private
PUBLIC_IMAGES_DISK=s3_public

FILE_DOMAIN_PUBLIC_IMAGES_PATH=public/images
FILE_DOMAIN_MEDICAL_DOCUMENTS_PATH=medical/documents
FILE_DOMAIN_LGPD_EXPORTS_PATH=lgpd/exports
FILE_DOMAIN_LGPD_EXPORTS_RETENTION_DAYS=7
FILE_DOMAIN_PRESCRIPTIONS_PATH=medical/prescriptions
FILE_DOMAIN_CERTIFICATES_PATH=medical/certificates
FILE_DOMAIN_CHAT_ATTACHMENTS_PATH=chat/attachments
FILE_DOMAIN_INTEGRATION_DOCUMENTS_PATH=integrations/documents
FILE_DOMAIN_VIDEO_RECORDINGS_PATH=calls/recordings

# -----------------------------------------------------------------------------
# SFU MediaSoup remoto no Hetzner. Nao configure SFU_ANNOUNCED_IP no PC1.
# -----------------------------------------------------------------------------
SFU_HTTP_URL=http://hetzner-sfu.tailnet.example:3080
SFU_WS_URL=wss://sfu.seudominio.com
SFU_API_SECRET=
SFU_JWT_SECRET=
SFU_NODE=hetzner

# -----------------------------------------------------------------------------
# Mail e notificacoes
# -----------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@seudominio.com"
MAIL_FROM_NAME="${APP_NAME}"

PUSH_ENABLED=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@seudominio.com

# -----------------------------------------------------------------------------
# Interoperabilidade / RNDS / PAdES
# -----------------------------------------------------------------------------
FHIR_SYSTEM_URL=https://app.seudominio.com/fhir
RNDS_ENABLED=false
RNDS_ENVIRONMENT=homologation
RNDS_BASE_URL=https://ehr-services-hmg.saude.gov.br/api
RNDS_AUTH_URL=https://ehr-auth-hmg.saude.gov.br/api
RNDS_CNES=
RNDS_CERTIFICATE_PATH=
RNDS_CERTIFICATE_PASSWORD=

SIGNATURE_DRIVER=null
SIGNATURE_A1_PFX_PATH=
SIGNATURE_A1_PFX_PASSWORD=
SIGNATURE_A1_CERT_FINGERPRINT=
SIGNATURE_A1_TRUSTED_CA_PATH=
SIGNATURE_A1_REQUIRE_DOCTOR_NAME_MATCH=true
SIGNATURE_VERIFICATION_URL_TEMPLATE=/verify/{code}

TELESCOPE_ENABLED=false
