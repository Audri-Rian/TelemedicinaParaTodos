# =============================================================================
# Variáveis mínimas para rodar local: APP_*, DB_*, BROADCAST_CONNECTION (ou log),
# QUEUE_CONNECTION, CACHE_STORE. Para tempo real: REVERB_*. Para produção: Mail, Storage (S3).
# =============================================================================

APP_NAME="Telemedicina Para Todos"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Banco de dados: pgsql (PostgreSQL) ou mysql
# Para ambiente local com Docker: DB_PASSWORD=secret. Portas abaixo são do docker-compose.dev.yml (composer run dev) para não conflitar com outros containers.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5434
DB_DATABASE=telemedicina
DB_USERNAME=postgres
DB_PASSWORD=secret

# Exemplo para MySQL (use DB_PORT=3306)
# DB_CONNECTION=mysql
# DB_PORT=3306
# DB_DATABASE=telemedicina
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcasting: log (desativado), reverb (WebSocket). No Docker Compose o Reverb sobe como serviço na porta 8080.
BROADCAST_CONNECTION=log
# Reverb (WebSocket) — notificações/atualizações em tempo real. Preencha para ativar; use BROADCAST_CONNECTION=log para desativar.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
# Servidor Reverb (container): escuta em REVERB_SERVER_HOST:REVERB_SERVER_PORT. No Docker: 0.0.0.0:8080.
REVERB_SERVER_HOST=127.0.0.1  # Use 0.0.0.0 em containers Docker
REVERB_SERVER_PORT=8080

# Storage padrão da aplicação. Mantenha "local" no desenvolvimento.
FILESYSTEM_DISK=local

# Storages por tipo/sensibilidade. DEV usa MinIO com os discos S3 abaixo.
MEDICAL_RECORDS_DISK=local
MEDICAL_DOCUMENTS_DISK=s3_private
LGPD_EXPORTS_DISK=s3_private
PRESCRIPTIONS_DISK=s3_private
CERTIFICATES_DISK=s3_private
CHAT_ATTACHMENTS_DISK=s3_private
INTEGRATION_DOCUMENTS_DISK=s3_private
VIDEO_RECORDINGS_DISK=s3_private
PUBLIC_IMAGES_DISK=s3_public

# Healthcheck/retention do subsistema de storage
STORAGE_HEALTHCHECK_CRON=*/5 * * * *
STORAGE_RETENTION_CLEANUP_CRON=0 2 * * *

# Paths por domínio de arquivo
FILE_DOMAIN_PUBLIC_IMAGES_PATH=public/images
FILE_DOMAIN_MEDICAL_DOCUMENTS_PATH=medical/documents
FILE_DOMAIN_LGPD_EXPORTS_PATH=lgpd/exports
FILE_DOMAIN_LGPD_EXPORTS_RETENTION_DAYS=7
FILE_DOMAIN_PRESCRIPTIONS_PATH=medical/prescriptions
FILE_DOMAIN_CERTIFICATES_PATH=medical/certificates
FILE_DOMAIN_CHAT_ATTACHMENTS_PATH=chat/attachments
FILE_DOMAIN_INTEGRATION_DOCUMENTS_PATH=integrations/documents
FILE_DOMAIN_VIDEO_RECORDINGS_PATH=calls/recordings

# S3 privado (prontuários, documentos médicos, exportações LGPD).
AWS_PRIVATE_BUCKET=telemedicina-private
AWS_PRIVATE_ROOT=private
AWS_PRIVATE_URL=

# S3 público (imagens/avatares/assets públicos, quando habilitado no código).
AWS_PUBLIC_BUCKET=telemedicina-public
AWS_PUBLIC_ROOT=public
AWS_PUBLIC_URL=

# CDN pública para imagens/avatares (placeholder DEV até CDN real).
CDN_PUBLIC_URL=https://cdn-dev.telemedicina.local

# Queue: "database" não exige Redis; "redis" usa as variáveis REDIS_* abaixo para processar jobs em background.
QUEUE_CONNECTION=database

# Cache: "database" ou "file" sem Redis; "redis" exige Redis rodando.
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Redis — obrigatório se CACHE_STORE=redis ou QUEUE_CONNECTION=redis.
# predis = PHP puro (recomendado). phpredis = extensão nativa (apt install php-redis).
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6380

# RabbitMQ (opcional: use QUEUE_CONNECTION=rabbitmq para filas críticas; padrão do dia a dia: redis)
# Porta 5673 = docker-compose.dev.yml (composer run dev). Para compose principal use 5672.
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5673
RABBITMQ_USER=telemedicina
RABBITMQ_PASSWORD=secret
RABBITMQ_VHOST=/
# RABBITMQ_QUEUE=default
# RABBITMQ_RETRY_AFTER=90

# Mail: "log" apenas grava em log; configure SMTP (ou provider) para envio real.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# S3 / MinIO. Use credencial de aplicação (não root/admin) para Laravel.
AWS_ACCESS_KEY_ID=telemedicina-app
AWS_SECRET_ACCESS_KEY=telemedicina-app-secret
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
# DEV no host: AWS_ENDPOINT=http://localhost:9000
# DEV em container: AWS_ENDPOINT=http://minio:9000
# MinIO remoto (outro computador na rede): AWS_ENDPOINT=http://192.168.1.50:9000
AWS_ENDPOINT=http://localhost:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# Credenciais do MinIO para bootstrap dos containers (docker-compose)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_APP_USER=telemedicina-app
MINIO_APP_PASSWORD=telemedicina-app-secret

# =============================================================================
# Interoperabilidade (FHIR / RNDS / Integrações com parceiros externos)
# =============================================================================
# Limite de linhas para relatório de acessos LGPD.
LGPD_ACCESS_REPORT_MAX_LOGS=1000

# Ver: config/integrations.php, execute/MVP1.md, feature-interoperability-pendencias.md

# URL base usada como system identifier nos recursos FHIR emitidos por este sistema.
# Formato: URL completa (http:// ou https://) correspondente ao domínio de produção.
# IMPORTANTE: uma vez usado em produção, NÃO altere este valor — ele entra como
# 'system' em cada identifier dos recursos FHIR já emitidos, e alterar quebra
# a integridade referencial de dados históricos (RNDS, parceiros, prontuário).
# Revise cuidadosamente antes de promover para produção.
FHIR_SYSTEM_URL=https://telemedicina.example.com/fhir

# RNDS (Rede Nacional de Dados em Saúde — DATASUS). Mantenha RNDS_ENABLED=false
# até concluir: registro no Portal DATASUS + CNES ativo + certificado e-CNPJ.
RNDS_ENABLED=false
RNDS_ENVIRONMENT=homologation            # homologation | production
RNDS_BASE_URL=https://ehr-services-hmg.saude.gov.br/api
RNDS_AUTH_URL=https://ehr-auth-hmg.saude.gov.br/api
RNDS_CNES=
# Certificado e-CNPJ A1 (arquivo .pfx/.p12). Segurança:
#   - chmod 600 no arquivo (somente owner); nunca commitar no repo;
#   - em produção, prefira secrets manager (AWS Secrets Manager, Vault, GCP
#     Secret Manager) e monte o .pfx via volume/init-container em vez de baixá-lo;
#   - em CI, injete via secret encryption (GitHub Actions secrets + base64).
RNDS_CERTIFICATE_PATH=                    # Ex.: /var/secrets/e-cnpj.pfx (PKCS12 A1)
RNDS_CERTIFICATE_PASSWORD=                # NUNCA em plaintext no repo — use secret manager.

# Fila dedicada para jobs de integração.
#   - RabbitMQ é recomendado para integrações externas (persistência em disco,
#     acks explícitos, dead-letter queue, retry patterns nativos). Quedas da API
#     do parceiro não perdem jobs.
#   - "database" funciona bem para tasks internas/menos críticas. Se o .env
#     principal já usa QUEUE_CONNECTION=database e você não tem RabbitMQ rodando,
#     pode trocar INTEGRATION_QUEUE_CONNECTION=database aqui também — vai
#     degradar resiliência mas manter funcionamento.
INTEGRATION_QUEUE_CONNECTION=rabbitmq
INTEGRATION_QUEUE_NAME=integrations

# Exportação de prontuário (assíncrona). Pode usar fila padrão ou dedicada.
# Exemplos:
#   - MEDICAL_RECORD_EXPORT_QUEUE_CONNECTION=database (ambiente local)
#   - MEDICAL_RECORD_EXPORT_QUEUE_CONNECTION=rabbitmq (produção com broker)
MEDICAL_RECORD_EXPORT_QUEUE_CONNECTION=database
MEDICAL_RECORD_EXPORT_QUEUE_NAME=default

# Timeouts (segundos) por tipo de parceiro. Defaults no config/integrations.php.
# INTEGRATION_LAB_CONNECT_TIMEOUT=5
# INTEGRATION_LAB_RESPONSE_TIMEOUT=15
# INTEGRATION_PHARMACY_CONNECT_TIMEOUT=3
# INTEGRATION_PHARMACY_RESPONSE_TIMEOUT=10
# INTEGRATION_HOSPITAL_CONNECT_TIMEOUT=5
# INTEGRATION_HOSPITAL_RESPONSE_TIMEOUT=15
# INTEGRATION_INSURANCE_CONNECT_TIMEOUT=5
# INTEGRATION_INSURANCE_RESPONSE_TIMEOUT=15
# INTEGRATION_RNDS_CONNECT_TIMEOUT=10
# INTEGRATION_RNDS_RESPONSE_TIMEOUT=60

# Circuit breaker — thresholds e cooling (segundos). Defaults no config.
# CB_LAB_FAILURES=5
# CB_LAB_COOLING=60
# CB_PHARMACY_FAILURES=3
# CB_PHARMACY_COOLING=30
# CB_HOSPITAL_FAILURES=5
# CB_HOSPITAL_COOLING=60
# CB_RNDS_FAILURES=10
# CB_RNDS_COOLING=120

# Retry (max_attempts por operação)
# RETRY_EXAM_ORDER_MAX=5
# RETRY_EXAM_RESULT_MAX=3
# RETRY_PRESCRIPTION_MAX=5
# RETRY_RNDS_MAX=10
# RETRY_WEBHOOK_MAX=5

# Rate limiting da API pública (por tipo de parceiro)
# RATE_LIMIT_LAB_PER_MINUTE=60
# RATE_LIMIT_LAB_PER_HOUR=1000
# RATE_LIMIT_LAB_PER_DAY=10000
# (ver config/integrations.php para demais tipos)

# Sync schedule (cron de pull automático)
# SYNC_EXAM_RESULTS_CRON="*/15 * * * *"
# SYNC_RETRY_QUEUE_CRON="*/5 * * * *"

# Segurança de webhook (tolerância de timestamp em segundos para HMAC).
# Default no config/integrations.php: 300 (5 min).
# WEBHOOK_TIMESTAMP_TOLERANCE=300

# SFU MediaSoup — página de teste em /sfu-test. Ver docs/videocall/TESTE_SFU_MEDIASOUP.md
# Use os mesmos valores de SFU_API_SECRET e SFU_JWT_SECRET no mediasoup-server (mediasoup-server/).
# SFU_HTTP_PORT=3080
# SFU_HTTP_URL=http://127.0.0.1:3080
# SFU_WS_URL=ws://127.0.0.1:4443
# SFU_API_SECRET=
# SFU_JWT_SECRET=
# OBRIGATÓRIO para vídeo funcionar: IP que o mediasoup anuncia nos candidatos ICE.
# Local: 127.0.0.1 | Produção/LAN: IP público ou privado da máquina (ex. 192.168.1.10)
# Sem este valor o mediasoup anuncia 0.0.0.0 e o browser não consegue estabelecer ICE.
# SFU_ANNOUNCED_IP=127.0.0.1

VITE_APP_NAME="${APP_NAME}"

# Assinatura digital PAdES ICP-Brasil (CFM Res. 2.314/2022)
# Drivers: null (dev/staging), a1_local (produção com certificado A1 PFX)
SIGNATURE_DRIVER=null
SIGNATURE_A1_PFX_PATH=
SIGNATURE_A1_PFX_PASSWORD=
SIGNATURE_A1_CERT_FINGERPRINT=
SIGNATURE_A1_TRUSTED_CA_PATH=
SIGNATURE_A1_REQUIRE_DOCTOR_NAME_MATCH=true
SIGNATURE_VERIFICATION_URL_TEMPLATE=/verify/{code}
