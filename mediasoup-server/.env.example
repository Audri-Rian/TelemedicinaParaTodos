# =============================================================================
# MediaSoup SFU — Configuração
# Copie este arquivo para .env e preencha os valores.
# Os valores de SFU_API_SECRET e SFU_JWT_SECRET devem ser IGUAIS aos do Laravel.
# =============================================================================

# ---------------------
# HTTP API
# ---------------------
SFU_HTTP_PORT=3000
# SFU_API_RATE_LIMIT_WINDOW_MS=60000
# SFU_API_RATE_LIMIT_MAX=10

# ---------------------
# WebSocket (sinalização WebRTC)
# ---------------------
SFU_WS_PORT=4443
# SFU_WS_HEARTBEAT_INTERVAL_MS=10000
# SFU_WS_HEARTBEAT_TIMEOUT_MS=30000

# ---------------------
# Autenticação (compartilhar com o Laravel)
# ---------------------
SFU_API_SECRET=
SFU_JWT_SECRET=

# ---------------------
# Rede / ICE
# ---------------------
SFU_LISTEN_IP=0.0.0.0
SFU_ANNOUNCED_IP=127.0.0.1
# SFU_RTC_MIN_PORT=40000
# SFU_RTC_MAX_PORT=49999

# ---------------------
# MediaSoup Workers
# ---------------------
# SFU_NUM_WORKERS=           # padrão: número de CPUs

# ---------------------
# Rooms
# ---------------------
# SFU_ROOM_EMPTY_GRACE_MS=30000

# ---------------------
# ICE/STUN/TURN (opcional)
# ---------------------
# SFU_STUN_URL=stun:stun.l.google.com:19302
# SFU_TURN_URL=
# SFU_TURN_USERNAME=
# SFU_TURN_CREDENTIAL=

# ---------------------
# Identificação do nó (opcional, padrão: hostname)
# ---------------------
# SFU_NODE_ID=sfu-01
